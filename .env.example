# Configuración SMTP para el formulario de contacto
# Copia este archivo a `.env` (que NO debe subirse a Git) y rellena los datos.

PORT=3000

SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp

# Destino de los mensajes del formulario (si lo dejas vacío usará SMTP_USER)
CONTACT_TO=elrincondebeita@yahoo.com
